# SkillArena.id — Environment Variables Template
# Copy file ini jadi .env dan isi dengan nilai aslinya
# JANGAN push file .env ke GitHub!

# ─────────────────────────────────────────
# SUPABASE
# ─────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJhbGc...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...        # RAHASIA — hanya di Netlify Functions

# ─────────────────────────────────────────
# OPENROUTER (AI Generate Soal)
# ─────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-...                # RAHASIA

# ─────────────────────────────────────────
# ZENZIVA (OTP SMS)
# ─────────────────────────────────────────
ZENZIVA_USERKEY=                            # RAHASIA
ZENZIVA_PASSKEY=                            # RAHASIA

# ─────────────────────────────────────────
# MIDTRANS (Payment Gateway)
# ─────────────────────────────────────────
MIDTRANS_SERVER_KEY=SB-Mid-server-...       # RAHASIA — hanya di server
MIDTRANS_CLIENT_KEY=SB-Mid-client-...       # Aman di frontend
MIDTRANS_IS_PRODUCTION=false                # true saat live

# ─────────────────────────────────────────
# FINGERPRINTJS (Device Fingerprint)
# ─────────────────────────────────────────
FPJS_API_KEY=                               # Opsional untuk versi pro

# ─────────────────────────────────────────
# APP CONFIG
# ─────────────────────────────────────────
APP_URL=https://skillarena.netlify.app      # URL platform
APP_ENV=development                          # development / production
MAX_DAILY_TOURNAMENTS=10                     # Batas turnamen/hari (absolut)
MAX_DAILY_SPEND=50000                        # Batas pengeluaran/hari dalam Rupiah (absolut)
DEFAULT_DAILY_TOURNAMENTS=5                  # Default batas turnamen/hari akun baru
DEFAULT_DAILY_SPEND=25000                    # Default batas pengeluaran/hari akun baru
MAX_PRIZE_PER_TOURNAMENT=500000             # Hadiah maks per turnamen (Rupiah)
MAX_PRIZE_PER_DAY=500000                    # Hadiah kumulatif maks per user per hari
MIN_TOPUP=10000                              # Minimum top up (Rupiah)
MIN_WITHDRAW=10000                           # Minimum WD (Rupiah)
MAX_ADS_PER_DAY=6                           # Maks iklan per user per hari
COINS_PER_AD=10                              # Koin per iklan (iklan 1-3)
COINS_PER_AD_REDUCED=5                      # Koin per iklan (iklan 4-6)
